Vagrant.configure("2") do |config|
  config.ssh.private_key_path = "key"
  config.ssh.insert_key = false

  config.vm.define "db" do |c|
    c.vm.box = "db"
    c.vm.network "private_network", ip: "192.168.56.30"
    c.vm.provider "virtualbox" do |v|
      v.memory = 1024
      v.cpus = 1
    end
    c.vm.provision "shell", inline: <<-SHELL
      set -eux
      sudo -u postgres psql -f /vagrant/users.sql
      grep -q '192.168.56.10 front' /etc/hosts || echo 192.168.56.10 front >> /etc/hosts
      grep -q '192.168.56.20 back' /etc/hosts || echo 192.168.56.20 back >> /etc/hosts
      grep -q '192.168.56.30 db' /etc/hosts || echo 192.168.56.30 db >> /etc/hosts
    SHELL
  end

  config.vm.define "front" do |c|
    c.vm.box = "front"
    c.vm.network "forwarded_port", guest: 80, host: 8888
    c.vm.network "private_network", ip: "192.168.56.10"
    c.vm.provider "virtualbox" do |v|
      v.memory = 1024
      v.cpus = 1
    end
    c.vm.provision "shell", inline: <<-SHELL
      set -eux
      cp /vagrant/index.html /var/www/html/index.html
      grep -q '192.168.56.10 front' /etc/hosts || echo 192.168.56.10 front >> /etc/hosts
      grep -q '192.168.56.20 back' /etc/hosts || echo 192.168.56.20 back >> /etc/hosts
      grep -q '192.168.56.30 db' /etc/hosts || echo 192.168.56.30 db >> /etc/hosts
    SHELL
  end

  config.vm.define "back" do |c|
    c.vm.box = "back"
    c.vm.network "forwarded_port", guest: 80, host: 8889
    c.vm.network "private_network", ip: "192.168.56.20"
    c.vm.provider "virtualbox" do |v|
      v.memory = 1024
      v.cpus = 1
    end
    c.vm.provision "shell", inline: <<-SHELL
      set -eux
      grep -q '192.168.56.10 front' /etc/hosts || echo 192.168.56.10 front >> /etc/hosts
      grep -q '192.168.56.20 back' /etc/hosts || echo 192.168.56.20 back >> /etc/hosts
      grep -q '192.168.56.30 db' /etc/hosts || echo 192.168.56.30 db >> /etc/hosts
      cp /vagrant/main.go /home/vagrant/main.go
      cd /home/vagrant
      go mod init example || true
      go mod tidy
      go build -o /usr/local/bin/lab2-back main.go
      printf '%s\n' \
        '[Unit]' \
        'Description=lab2 backend service' \
        'After=network.target' \
        '' \
        '[Service]' \
        'WorkingDirectory=/home/vagrant' \
        'ExecStart=/usr/local/bin/lab2-back' \
        'Restart=always' \
        'RestartSec=3' \
        '' \
        '[Install]' \
        'WantedBy=multi-user.target' \
        >/etc/systemd/system/lab2-back.service
      systemctl daemon-reload
      systemctl enable --now lab2-back.service
    SHELL
  end
end
