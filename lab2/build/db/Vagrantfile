Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.ssh.insert_key = false
  config.vm.boot_timeout = 600
  config.vm.provider "virtualbox" do |v|
    v.memory = 1024
    v.cpus = 1
  end
  config.vm.provision "shell", inline: <<-SHELL
    set -eux
    apt-get update
    apt-get install -y postgresql
    PGVER=$(ls /etc/postgresql | head -n 1)
    echo "listen_addresses = '*'" > /etc/postgresql/$PGVER/main/conf.d/listen.conf
    grep -q "host all all 0.0.0.0/0 trust" /etc/postgresql/$PGVER/main/pg_hba.conf || echo "host all all 0.0.0.0/0 trust" >> /etc/postgresql/$PGVER/main/pg_hba.conf
    systemctl restart postgresql
  SHELL
end
