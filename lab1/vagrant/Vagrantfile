Vagrant.configure("2") do |config|
  # ubuntu/lunar64 from the original task is EOL; use a current LTS box.
  config.vm.box = "ubuntu/jammy64"

  config.vm.network "forwarded_port", guest: 80, host: 8080

  config.vm.provision "shell", inline: <<-SHELL
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y golang-go
    /usr/bin/go build -o /usr/local/bin/hello-vagrant /vagrant/main.go

    printf '%s\n' \
      '[Unit]' \
      'Description=Simple HTTP app for infra-course lab1' \
      'After=network.target' \
      '' \
      '[Service]' \
      'ExecStart=/usr/local/bin/hello-vagrant' \
      'Restart=always' \
      'RestartSec=3' \
      '' \
      '[Install]' \
      'WantedBy=multi-user.target' \
      >/etc/systemd/system/hello-vagrant.service

    systemctl daemon-reload
    systemctl enable --now hello-vagrant.service
  SHELL
end
